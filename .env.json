[
    {
        "env_name": "KAFKA_BOOTSTRAP_SERVERS",
        "variable_type": "String",
        "mandatory": true,
        "default_value": "localhost:9092",
        "about_variable": "Comma-separated list of Kafka broker addresses."
    },
    {
        "env_name": "KAFKA_TOPIC",
        "variable_type": "String",
        "mandatory": true,
        "default_value": "telematics",
        "about_variable": "The Kafka topic to produce messages to."
    },
    {
        "env_name": "NUM_TRUCKS",
        "variable_type": "Integer",
        "mandatory": false,
        "default_value": "5",
        "about_variable": "The number of simulated trucks."
    },
    {
        "env_name": "SIMULATION_INTERVAL_SECONDS",
        "variable_type": "Integer",
        "mandatory": false,
        "default_value": "1",
        "about_variable": "The delay between sending batches of data for all trucks, in seconds."
    },
    {
        "env_name": "STATUS_CHANGE_PROBABILITY",
        "variable_type": "Float",
        "mandatory": false,
        "default_value": "0.1",
        "about_variable": "The probability (0.0 to 1.0) of a truck's online/offline status changing."
    },
    {
        "env_name": "CARGO_CHANGE_PROBABILITY",
        "variable_type": "Float",
        "mandatory": false,
        "default_value": "0.2",
        "about_variable": "The probability (0.0 to 1.0) of a truck's cargo attachment status changing."
    }
]